{
  "id": "openclaw-plugin",
  "name": "ClawLink",
  "description": "Hosted connection sessions for ClawLink integrations inside OpenClaw",
  "version": "0.1.2",
  "skills": [
    "skills"
  ],
  "contracts": {
    "tools": [
      "clawlink_start_connection",
      "clawlink_get_connection_status"
    ]
  },
  "uiHints": {
    "apiKey": {
      "label": "ClawLink API key",
      "help": "Bearer token created in the ClawLink dashboard.",
      "placeholder": "cllk_live_...",
      "sensitive": true
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
