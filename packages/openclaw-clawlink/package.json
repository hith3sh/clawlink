{
  "name": "@useclawlink/openclaw-plugin",
  "version": "0.1.33",
  "description": "Trusted SaaS integrations for OpenClaw agents through the ClawLink plugin",
  "type": "module",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/hith3sh/clawlink"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "clawlink",
    "openclaw",
    "plugin",
    "oauth",
    "integrations"
  ],
  "files": [
    "index.js",
    "openclaw.plugin.json",
    "README.md",
    "skills"
  ],
  "exports": {
    ".": "./index.js"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49"
  },
"openclaw": {
    "extensions": [
      "./index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.13",
      "minGatewayVersion": "2026.3.13"
    },
    "build": {
      "openclawVersion": "2026.4.5",
      "pluginSdkVersion": "2026.4.5"
    }
  }
}
