{
  "name": "clawlink",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:web": "opennextjs-cloudflare build --config wrangler.toml",
    "deploy:web": "env $(grep -v '^#' .env.production | grep '=' | xargs) opennextjs-cloudflare build --config wrangler.toml && wrangler deploy",
    "build:worker": "echo 'Worker build is handled by Wrangler during deploy'",
    "deploy:worker": "wrangler --cwd worker deploy --config wrangler.worker.toml --experimental-autoconfig=false",
    "start": "next start",
    "lint": "eslint",
    "version:worker": "wrangler versions upload --config worker/wrangler.worker.toml"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@clerk/nextjs": "^7.0.8",
    "@opennextjs/cloudflare": "^1.18.0",
    "@polar-sh/nextjs": "^0.9.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "next": "^15.5.2",
    "openclaw": "^2026.4.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260401.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.80.0"
  }
}
